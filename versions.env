# Pinned inputs for a reproducible mermaid-searxng bundle.
# Bumped by CI / release PRs. Keep BUNDLE_VERSION in lockstep with the git tag.

BUNDLE_VERSION=v0.1.0

# Portable interpreter: astral-sh/python-build-standalone release + CPython version.
CPYTHON_TAG=20260623
CPYTHON_VERSION=3.12.13

# SearXNG source, pinned to an exact commit for byte-stable rebuilds.
SEARXNG_REF=1412926f5c80ffabc90719450578eb98fda9e161

# Granian (the ASGI/WSGI server that runs SearXNG). Not a SearXNG dependency, so
# it is installed and pinned separately.
GRANIAN_VERSION=2.7.9
