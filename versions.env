# Pinned inputs for a reproducible mermaid-searxng bundle.
# Bumped by CI / release PRs. Keep BUNDLE_VERSION in lockstep with the git tag.
# After changing SEARXNG_REF or GRANIAN_VERSION, rerun scripts/update-lock.sh
# to regenerate requirements.lock.

BUNDLE_VERSION=v0.3.0

# Portable interpreter: astral-sh/python-build-standalone release + CPython
# version, `install_only_stripped` variant (no debug symbols). The per-triple
# sha256 pins come from the PBS release's SHA256SUMS and are the build's trust
# anchor for the interpreter download (keys are the PBS triple with '-' -> '_'
# so this file stays bash-sourceable).
CPYTHON_TAG=20260623
CPYTHON_VERSION=3.12.13
CPYTHON_SHA256_x86_64_unknown_linux_gnu=10a452caac7041357805f0c19a60576df53f1ab06d1abfc9200f1f0157cb3bd1
CPYTHON_SHA256_aarch64_unknown_linux_gnu=b85154b9c7ca9de3f85f2c9f032d503151db16ef198de86b885fc61890c075ed
CPYTHON_SHA256_aarch64_apple_darwin=41df7d3ae4757e84b97874f76d634268456aaa271740d33f968d826374998fb7
CPYTHON_SHA256_x86_64_apple_darwin=a6bbea996c5f14eb55ab275889d2df45408deec504b4a7219d7b59c045b2555e

# SearXNG source, pinned to an exact commit. Fetched via git, so the bytes are
# verified against this hash by git itself (no archive-tarball trust needed).
SEARXNG_REF=1412926f5c80ffabc90719450578eb98fda9e161

# Granian (the ASGI/WSGI server that runs SearXNG). Not a SearXNG dependency, so
# it is installed and pinned separately (hash-locked via requirements.lock).
GRANIAN_VERSION=2.7.9

# Timestamp clamp for byte-stable rebuilds: applied to wheel-build metadata
# (SOURCE_DATE_EPOCH) and every file mtime in the packed tarball. Set to the
# SEARXNG_REF commit date; refresh alongside SEARXNG_REF bumps.
SOURCE_DATE_EPOCH=1783538351
